{
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/dist": true,
    "backend/data": true,
    "backend/uploads": true,
    "data": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/dist/**": true,
    "backend/data/**": true,
    "backend/uploads/**": true,
    "data/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/package-lock.json": true,
    "backend/data": true,
    "backend/uploads": true,
    "data": true
  },
  "typescript.tsserver.watchOptions": {
    "excludeDirectories": ["**/node_modules", "**/dist", "**/backend/data", "**/backend/uploads"]
  }
}
