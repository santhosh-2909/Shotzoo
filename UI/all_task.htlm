<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "on-surface": "#151c27",
                    "on-secondary": "#ffffff",
                    "background": "#f9f9ff",
                    "on-surface-variant": "#444939",
                    "surface": "#f9f9ff",
                    "secondary": "#0058be",
                    "on-secondary-fixed-variant": "#004395",
                    "on-tertiary-fixed-variant": "#653e00",
                    "tertiary-fixed-dim": "#ffb95f",
                    "secondary-fixed-dim": "#adc6ff",
                    "inverse-primary": "#aed367",
                    "on-primary": "#ffffff",
                    "primary-container": "#a8cd62",
                    "on-secondary-container": "#fefcff",
                    "on-tertiary-fixed": "#2a1700",
                    "surface-dim": "#d3daea",
                    "surface-container": "#e7eefe",
                    "on-background": "#151c27",
                    "tertiary-container": "#ffb044",
                    "on-primary-container": "#3c5600",
                    "secondary-fixed": "#d8e2ff",
                    "on-error": "#ffffff",
                    "surface-container-high": "#e2e8f8",
                    "on-secondary-fixed": "#001a42",
                    "surface-container-highest": "#dce2f3",
                    "surface-container-lowest": "#ffffff",
                    "primary": "#496800",
                    "outline": "#757968",
                    "inverse-surface": "#2a313d",
                    "error-container": "#ffdad6",
                    "inverse-on-surface": "#ebf1ff",
                    "primary-fixed": "#c9f080",
                    "surface-variant": "#dce2f3",
                    "on-primary-fixed": "#131f00",
                    "secondary-container": "#2170e4",
                    "surface-bright": "#f9f9ff",
                    "on-error-container": "#93000a",
                    "surface-tint": "#496800",
                    "error": "#ba1a1a",
                    "tertiary": "#855300",
                    "on-tertiary-container": "#6f4500",
                    "primary-fixed-dim": "#aed367",
                    "outline-variant": "#c4c9b5",
                    "on-tertiary": "#ffffff",
                    "tertiary-fixed": "#ffddb8",
                    "surface-container-low": "#f0f3ff",
                    "on-primary-fixed-variant": "#364e00"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "14px",
                    "xl": "18px",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Space Grotesk"],
                    "body": ["Manrope"],
                    "label": ["Inter"],
                    "mono": ["JetBrains Mono"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .shadow-panel { box-shadow: 0 0 40px rgba(0,0,0,0.12); }
        .shadow-card { box-shadow: 0 2px 8px rgba(0,0,0,0.04), 0 8px 24px rgba(0,0,0,0.06), inset 0 1px 0 rgba(255,255,255,0.8); }
        body { font-family: 'Manrope', sans-serif; background-color: #F7F8F4; color: #151c27; }
        .font-editorial-header { font-family: 'Space Grotesk', sans-serif; letter-spacing: -0.02em; }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
</head>
<body class="antialiased overflow-x-hidden">
<!-- Top Navigation Bar (Shared) -->
<header class="fixed top-0 w-full z-40 flex justify-between items-center px-6 h-16 bg-[#F7F8F4] dark:bg-stone-950 transition-all duration-200">
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-stone-500 hover:bg-[#E2E8F8] p-2 rounded-full transition-all active:scale-95">menu</button>
<h1 class="font-['Space_Grotesk'] font-bold tracking-tight text-xl text-stone-900 dark:text-stone-100">Dashboard</h1>
</div>
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-stone-500 hover:bg-[#E2E8F8] p-2 rounded-full transition-all">search</button>
<div class="w-10 h-10 rounded-full overflow-hidden border-2 border-[#A8CD62]/20">
<img alt="User Profile" class="w-full h-full object-cover" data-alt="Close-up portrait of a professional male manager in a clean white studio setting with soft natural lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB2xUUQkAhsXGx0y_A-BWM29EbrzOLdr_FnNERZCubjRrSaOfVGlUJ8KnU9ET5VU4MQbUE7bQLAZI8nxYlNdqRTpbjBR8_EaEMitlP6HXsssAE_p6f_Cgh2LC66uxGQ6XFD5IGyx6kXN2iRxWRYo8iq9VuaXwh0rO9lXFMUJ4U1-xonWwiMsQuxj846j4wDk--y2Brnp3khf8J8MgAU6TMUDb5kxCLzMYdu2sZHyAGVUca5YxdgdKNMoc8wzg_rh-13bvCxWQO8kBpS"/>
</div>
</div>
</header>
<!-- Navigation Drawer (Shared) -->
<aside class="fixed left-0 top-0 h-full z-50 flex flex-col w-[260px] bg-[#FFFFFF] dark:bg-stone-900 shadow-panel transition-all duration-300 hidden md:flex">
<div class="p-8 pb-10">
<h2 class="font-['Space_Grotesk'] font-bold text-2xl text-[#A8CD62]">ShotZoo Admin</h2>
</div>
<nav class="flex-1 flex flex-col px-4 gap-1 overflow-y-auto">
<!-- Dashboard -->
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="/admin/dashboard.html">
<span class="material-symbols-outlined">dashboard</span>
                Dashboard
            </a>
<!-- Employees -->
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="/admin/emp_pg.html">
<span class="material-symbols-outlined">group</span>
                Employees
            </a>
<!-- All Tasks (ACTIVE) -->
<a class="flex items-center gap-3 px-4 py-3 border-l-[3px] border-[#A8CD62] bg-[#A8CD62]/10 text-[#A8CD62] transition-colors font-['Satoshi'] font-semibold text-sm" href="/admin/all_task.html">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">assignment</span>
                All Tasks
            </a>
<!-- My Tasks -->
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="#">
<span class="material-symbols-outlined">person_pin</span>
                My Tasks
            </a>
<!-- Add Task -->
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="/admin/add_task.html">
<span class="material-symbols-outlined">add_task</span>
                Add Task
            </a>
<!-- Attendance -->
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="/admin/attendence.html">
<span class="material-symbols-outlined">calendar_today</span>
                Attendance
            </a>
<!-- Analytics -->
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="#">
<span class="material-symbols-outlined">analytics</span>
                Analytics
            </a>
<!-- Send Notification -->
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="#">
<span class="material-symbols-outlined">send</span>
                Send Notification
            </a>
<div class="mt-auto pb-8 flex flex-col gap-1">
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-stone-600 dark:text-stone-400 hover:bg-[#F0F3FF] dark:hover:bg-stone-800 transition-colors font-['Satoshi'] font-semibold text-sm" href="#">
<span class="material-symbols-outlined">settings</span>
                    Settings
                </a>
<a class="flex items-center gap-3 px-4 py-3 rounded-lg text-[#EF4444] hover:bg-[#EF4444]/10 transition-colors font-['Satoshi'] font-semibold text-sm" href="/">
<span class="material-symbols-outlined text-[#EF4444]">logout</span>
                    Logout
                </a>
</div>
</nav>
</aside>
<!-- Main Content -->
<main class="md:ml-[260px] pt-24 px-6 pb-24 min-h-screen transition-all">
<!-- Editorial Header Section -->
<div class="max-w-7xl mx-auto">
<div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
<div>
<div class="flex items-center gap-4 mb-2">
<h2 class="text-4xl md:text-5xl font-editorial-header font-bold text-on-surface">All Tasks</h2>
<span class="bg-primary-container/20 text-on-primary-container px-3 py-1 rounded-full font-mono text-lg font-bold">128</span>
</div>
<p class="text-on-surface-variant font-medium text-lg opacity-80">Managing institutional workflow and editorial assignments.</p>
</div>
<div class="flex gap-3">
<button class="bg-error/10 text-error px-5 py-2.5 rounded-lg font-semibold flex items-center gap-2 hover:bg-error/20 transition-all active:scale-95">
<span class="material-symbols-outlined text-[20px]">notification_important</span>
                        Remind All Overdue
                    </button>
<button class="bg-[#A8CD62]/10 text-primary-fixed-dim bg-primary-container text-white px-5 py-2.5 rounded-lg font-semibold flex items-center gap-2 hover:bg-[#96B856] transition-all active:scale-95">
<span class="material-symbols-outlined text-[20px]">download</span>
                        Export
                    </button>
</div>
</div>
<!-- Filter Bar -->
<div class="bg-surface-container-low p-4 mb-8 flex flex-col lg:flex-row items-center gap-6 rounded-xl transition-all">
<div class="w-full lg:w-48">
<label class="block text-[10px] uppercase tracking-wider font-bold text-on-surface-variant mb-1 ml-1">Assigned To</label>
<select class="w-full bg-white border-none rounded-lg text-sm font-semibold text-on-surface focus:ring-2 focus:ring-[#A8CD62]">
<option>All Employees</option>
<option>Marcus Aurelius</option>
<option>Seneca Young</option>
</select>
</div>
<div class="flex-1 overflow-x-auto w-full no-scrollbar">
<label class="block text-[10px] uppercase tracking-wider font-bold text-on-surface-variant mb-1 ml-1">Status View</label>
<div class="flex items-center gap-2 whitespace-nowrap">
<button class="bg-primary-container text-white px-4 py-1.5 rounded-full text-sm font-bold shadow-sm">All</button>
<button class="bg-surface-container-high text-on-surface-variant px-4 py-1.5 rounded-full text-sm font-semibold hover:bg-surface-container-highest transition-colors">Pending</button>
<button class="bg-surface-container-high text-on-surface-variant px-4 py-1.5 rounded-full text-sm font-semibold hover:bg-surface-container-highest transition-colors">In Progress</button>
<button class="bg-surface-container-high text-on-surface-variant px-4 py-1.5 rounded-full text-sm font-semibold hover:bg-surface-container-highest transition-colors">Completed</button>
<button class="bg-error-container text-error px-4 py-1.5 rounded-full text-sm font-bold flex items-center gap-1">Overdue <span class="text-[10px] bg-error text-white px-1.5 rounded-full">12</span></button>
</div>
</div>
<div class="w-full lg:w-40">
<label class="block text-[10px] uppercase tracking-wider font-bold text-on-surface-variant mb-1 ml-1">Priority</label>
<select class="w-full bg-white border-none rounded-lg text-sm font-semibold text-on-surface focus:ring-2 focus:ring-[#A8CD62]">
<option>Any Priority</option>
<option>High</option>
<option>Medium</option>
<option>Low</option>
</select>
</div>
<div class="w-full lg:w-64 relative">
<label class="block text-[10px] uppercase tracking-wider font-bold text-on-surface-variant mb-1 ml-1">Search Tasks</label>
<input class="w-full pl-10 bg-white border-none rounded-lg text-sm font-semibold text-on-surface focus:ring-2 focus:ring-[#A8CD62]" placeholder="ID, Title, or Tag..." type="text"/>
<span class="material-symbols-outlined absolute left-3 top-[30px] text-stone-400 text-[20px]">search</span>
</div>
</div>
<!-- Task Table Card -->
<div class="bg-surface-container-lowest rounded-xl shadow-card overflow-hidden">
<div class="overflow-x-auto">
<table class="w-full text-left border-collapse">
<thead>
<tr class="bg-surface-container-low/50">
<th class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Assignee</th>
<th class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Task Detail</th>
<th class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Priority</th>
<th class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Deadline</th>
<th class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant">Time Remaining</th>
<th class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant text-center">Status</th>
<th class="px-6 py-4 text-[10px] uppercase tracking-widest font-bold text-on-surface-variant text-right">Actions</th>
</tr>
</thead>
<tbody class="divide-y divide-surface-container-low">
<!-- Row 1: OVERDUE -->
<tr class="hover:bg-surface-container-low transition-colors border-l-4 border-error">
<td class="px-6 py-4">
<div class="flex items-center gap-3">
<div class="w-9 h-9 rounded-full overflow-hidden bg-surface-container-high">
<img class="w-full h-full object-cover" data-alt="Portrait of a creative professional male with glasses smiling in a modern office" src="https://lh3.googleusercontent.com/aida-public/AB6AXuADVrgoP1O6TnroD9FOKbPV6DjmTjOB5cgp75anTvAEXQhfTa-OEqPSvrzZDwol8RFmnsUv25bmk9GowePKS15KgVrOWgLJuyzLrCRNyk_p9iN0xp0v2kAcv__UCF7HM832mMPbEBP529Z8JP3TlBUiDndv02218nlk3xNbun0ZBs1vvTZnJYOYhtb8z22RUiAXoSJ6Ex1lc5FAIYDaHoUfktQlB8ZD7eqpXA8vSULGLJCVjLd2YefLNIOq5h3LexT2e3dQNockXk9p"/>
</div>
<span class="text-sm font-bold text-on-surface">Alex Rivera</span>
</div>
</td>
<td class="px-6 py-4">
<div class="max-w-xs">
<p class="text-sm font-bold text-on-surface truncate">Quarterly Financial Review Phase 1</p>
<p class="text-[11px] text-on-surface-variant uppercase font-mono">ID: TSK-8821</p>
</div>
</td>
<td class="px-6 py-4">
<div class="flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-error"></span>
<span class="text-xs font-bold text-error uppercase">High</span>
</div>
</td>
<td class="px-6 py-4">
<span class="text-sm font-medium text-on-surface">Oct 12, 2023</span>
</td>
<td class="px-6 py-4">
<span class="font-mono text-xs font-bold text-error">- 2d 14h</span>
</td>
<td class="px-6 py-4 text-center">
<span class="bg-error/10 text-error px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight">Overdue</span>
</td>
<td class="px-6 py-4">
<div class="flex justify-end gap-2">
<button class="material-symbols-outlined text-stone-400 hover:text-primary transition-colors p-1.5 rounded-md hover:bg-primary/10">visibility</button>
<button class="material-symbols-outlined text-error hover:scale-110 transition-transform p-1.5 rounded-md hover:bg-error/10">notifications_active</button>
</div>
</td>
</tr>
<!-- Row 2: In Progress -->
<tr class="hover:bg-surface-container-low transition-colors border-l-4 border-transparent">
<td class="px-6 py-4">
<div class="flex items-center gap-3">
<div class="w-9 h-9 rounded-full overflow-hidden bg-surface-container-high">
<img class="w-full h-full object-cover" data-alt="Headshot of a confident young woman with a warm smile professional setting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAddpewT7hhcdpU6l62Tidgs1k2qItHdiihs4ced-DKEkzVghgo_dCpoIq0iqGSi-J1uVXISH0XqmvNHjDkC4AshK8oMPAQIejsvPaN6UtygEOPKNrh7LxPvFDj-EbraKzvDD0PKruYvdv4oZim_EoIjddxUdh-CG2mKjBFXh8eTqruCITjhQZcUYsQvuTiav0LcJOqyLxmplJ2bkah_qBRnQQ4OQXLj1Bh7xdRS_H3TnqBlliHDpYtxmgTkdctbiJL0Ai7z_Tg9G4Q"/>
</div>
<span class="text-sm font-bold text-on-surface">Sarah Chen</span>
</div>
</td>
<td class="px-6 py-4">
<div class="max-w-xs">
<p class="text-sm font-bold text-on-surface truncate">API Documentation Revamp</p>
<p class="text-[11px] text-on-surface-variant uppercase font-mono">ID: TSK-8902</p>
</div>
</td>
<td class="px-6 py-4">
<div class="flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-tertiary-container"></span>
<span class="text-xs font-bold text-tertiary-container uppercase">Medium</span>
</div>
</td>
<td class="px-6 py-4">
<span class="text-sm font-medium text-on-surface">Oct 16, 2023</span>
</td>
<td class="px-6 py-4">
<span class="font-mono text-xs font-bold text-tertiary-container">1d 08h</span>
</td>
<td class="px-6 py-4 text-center">
<span class="bg-secondary/10 text-secondary px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight">In Progress</span>
</td>
<td class="px-6 py-4">
<div class="flex justify-end gap-2">
<button class="material-symbols-outlined text-stone-400 hover:text-primary transition-colors p-1.5 rounded-md hover:bg-primary/10">visibility</button>
<button class="material-symbols-outlined text-stone-400 hover:text-primary transition-colors p-1.5 rounded-md hover:bg-primary/10">notifications</button>
</div>
</td>
</tr>
<!-- Row 3: Completed -->
<tr class="hover:bg-surface-container-low transition-colors border-l-4 border-transparent">
<td class="px-6 py-4">
<div class="flex items-center gap-3">
<div class="w-9 h-9 rounded-full overflow-hidden bg-surface-container-high">
<img class="w-full h-full object-cover" data-alt="Portrait of a young male professional against a soft grey background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCR5tp7snrl9qwlzFyOXibQ6eEUDkHfv6EwVgbgDJCsxjhM3AXWdrG7h4hpQ1ih8beisrqyKoL_rHwkFWczwK2FV8F4_jJ9RYT39Btotxvw63ClsBdeLlydnsPJZNo5roqPzrkjFtKBr54QyJVlwjFo2PPUntGxuglNmO0ygoL5g-cTfLDd-ET_PZbvXq5K83k4djRBoSaZ-Z8ZuiJ5aE6SocHU33oLaivnxf_JaZRY-i8ydWxn-oQWjd2U5ChPqrEokfHh_fU8te8v"/>
</div>
<span class="text-sm font-bold text-on-surface">Leo Hudson</span>
</div>
</td>
<td class="px-6 py-4">
<div class="max-w-xs">
<p class="text-sm font-bold text-on-surface truncate opacity-50 line-through">Security Patch Deployment</p>
<p class="text-[11px] text-on-surface-variant uppercase font-mono">ID: TSK-8812</p>
</div>
</td>
<td class="px-6 py-4">
<div class="flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-error"></span>
<span class="text-xs font-bold text-error uppercase">High</span>
</div>
</td>
<td class="px-6 py-4">
<span class="text-sm font-medium text-on-surface">Oct 11, 2023</span>
</td>
<td class="px-6 py-4">
<span class="material-symbols-outlined text-primary text-[20px]">check_circle</span>
</td>
<td class="px-6 py-4 text-center">
<span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-tight">Completed</span>
</td>
<td class="px-6 py-4">
<div class="flex justify-end gap-2">
<button class="material-symbols-outlined text-stone-400 hover:text-primary transition-colors p-1.5 rounded-md hover:bg-primary/10">visibility</button>
<button class="material-symbols-outlined text-stone-300 cursor-not-allowed p-1.5" disabled="">notifications_off</button>
</div>
</td>
</tr>
<!-- More rows (Simulated) -->
<tr class="hover:bg-surface-container-low transition-colors border-l-4 border-error">
<td class="px-6 py-4"><div class="flex items-center gap-3"><div class="w-9 h-9 rounded-full bg-surface-container-high"></div><span class="text-sm font-bold text-on-surface">Elena Rossi</span></div></td>
<td class="px-6 py-4"><div class="max-w-xs"><p class="text-sm font-bold text-on-surface truncate">Client Presentation Deck</p><p class="text-[11px] text-on-surface-variant font-mono">TSK-8920</p></div></td>
<td class="px-6 py-4"><div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-error"></span><span class="text-xs font-bold text-error uppercase">High</span></div></td>
<td class="px-6 py-4"><span class="text-sm font-medium text-on-surface">Oct 13, 2023</span></td>
<td class="px-6 py-4"><span class="font-mono text-xs font-bold text-error">- 1d 04h</span></td>
<td class="px-6 py-4 text-center"><span class="bg-error/10 text-error px-3 py-1 rounded-full text-[10px] font-bold uppercase">Overdue</span></td>
<td class="px-6 py-4 text-right"><button class="material-symbols-outlined text-error p-1.5">notifications_active</button></td>
</tr>
<!-- Repeated data structure for 12 rows... -->
