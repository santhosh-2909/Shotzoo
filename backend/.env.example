# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# 1. If MONGODB_URI is set AND reachable → used (production mode).
# 2. If MONGODB_URI is set but unreachable → warn, fall back to in-memory.
# 3. If MONGODB_URI is unset → start in-memory MongoDB directly.
# On first boot with an empty DB, the seeder creates:
#   - admin user:  admin@shotzoo.dev / admin123
#   - 3 employees, 6 sample tasks, 3 days of attendance
MONGODB_URI=mongodb://127.0.0.1:27017/shotzoo

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_character_hex_secret
JWT_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Set these to enable employee-ID welcome emails and OTP delivery.
# Leave EMAIL_USER unset or as the placeholder value to skip email sending
# (the server will log OTPs to the console instead — fine for development).
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled)
